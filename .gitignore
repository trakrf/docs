# Dependencies
node_modules/

# Git worktrees — Claude Code's native worktree tool writes here; this is the
# canonical location (gitignored). Narrow ignore: the rest of .claude/ stays tracked.
.claude/worktrees/

# Docusaurus
build/
.docusaurus/

# Generated build artifacts
# health.json — scripts/write-health-json.mjs (prebuild)
/static/health.json

# Environment variables
.env
.env.*
!.envrc
!.env.example

# OS
.DS_Store

# IDEs and editors
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~

# Claude Code local settings
.claude/settings.local.json

# Playwright MCP intermediate files
.playwright-mcp/

# CSW local symlink
spec/csw

# Black-box fixture-maintenance SQL — persistent across reboots, not committed.
# README.md inside the directory is exempted so the directory's purpose is documented in-repo.
tests/blackbox/.fixtures/*
!tests/blackbox/.fixtures/README.md
